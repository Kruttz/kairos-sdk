{
  "name": "@kairos-sdk/core",
  "version": "0.1.1",
  "description": "LLM-powered n8n workflow generation and deployment SDK",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "kairos": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "n8n",
    "workflow",
    "automation",
    "ai",
    "claude",
    "anthropic",
    "llm",
    "workflow-generation",
    "kairos",
    "no-code"
  ],
  "author": "Jordan Krutman",
  "license": "MIT",
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@types/node": "^20.0.0",
    "msw": "^2.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
