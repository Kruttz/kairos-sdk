{
  "name": "@kairos-sdk/core",
  "version": "0.4.5",
  "description": "LLM-powered n8n workflow generation — use as an SDK or MCP server",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "kairos": "dist/cli.js",
    "kairos-mcp": "dist/mcp-server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./standalone": {
      "types": "./dist/standalone.d.ts",
      "import": "./dist/standalone.js",
      "require": "./dist/standalone.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:e2e": "vitest run --dir tests/e2e",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "n8n",
    "workflow",
    "automation",
    "ai",
    "claude",
    "anthropic",
    "llm",
    "workflow-generation",
    "kairos",
    "no-code",
    "mcp",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kruttz/kairos-sdk.git"
  },
  "homepage": "https://github.com/Kruttz/kairos-sdk#readme",
  "bugs": {
    "url": "https://github.com/Kruttz/kairos-sdk/issues"
  },
  "author": "Jordan Krutman",
  "license": "MIT",
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@types/node": "^20.0.0",
    "msw": "^2.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
