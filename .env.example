# ============================================================
# Kairos SDK — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ── Required for workflow generation ──────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Required for n8n deployment / management ──────────────
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=n8n_api_...

# ── MCP server permissions (all default OFF for safety) ───
# Set to "true" to allow kairos_deploy tool
KAIROS_MCP_ALLOW_DEPLOY=false
# Set to "true" to allow kairos_activate tool
KAIROS_MCP_ALLOW_ACTIVATE=false
# Set to "true" to allow kairos_delete tool
KAIROS_MCP_ALLOW_DELETE=false

# ── Tuning (optional, all have sensible defaults) ─────────
# Claude model to use for generation (default: claude-sonnet-4-6)
KAIROS_MODEL=claude-sonnet-4-6

# Prompt verbosity: minimal | standard | rich (default: standard)
KAIROS_PROMPT_PROFILE=standard

# Max workflow entries in the local library (default: 500)
KAIROS_LIBRARY_SIZE=500

# Custom telemetry directory (default: ~/.kairos/telemetry)
# KAIROS_TELEMETRY_DIR=/path/to/telemetry
